@prefix tgs: <http://example.org/tgs#> .
@prefix thinkr: <http://example.org/thinkr#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dbo: <http://dbpedia.org/ontology/> .

# ============================================================
# PROTOTYPE ONLY — not committed to the real graph, not yet a decision.
# Built 2026-07-12 to answer "what would this actually look like with
# real data." TESTED: parses correctly (54 triples), correctly answers
# real queries (interaction counts, role-reversal detection, chronological
# history), correctly integrates with the real episodes.ttl once merged.
#
# PATTERN: a stable, NAMED thinkr:Relationship individual per person-pair
# (the "anchor" — queryable, referenceable, one per pair, never renamed)
# holding nested BLANK NODE interaction instances (no naming collision,
# no naming burden per instance — this is the fix for the multi-instance
# problem raised a few hours ago: McGilchrist's 3 separate appearances
# needed zero additional naming decisions, just 3 more blank nodes).
# ============================================================

# --- RelationshipType Category (same template as EpisodeType/PersonEntityType) ---
thinkr:RelationshipType a owl:Class, thinkr:Category ;
    rdfs:comment "What KIND of relationship this is — deliberately multi-valued (a relationship can be BOTH Professional AND have a Legal dimension simultaneously, not competing options)."@en ;
    skos:prefLabel "Relationship Type"@en .

thinkr:RelationshipType.Professional a thinkr:RelationshipType, owl:NamedIndividual ;
    skos:prefLabel "Professional"@en .

thinkr:RelationshipType.Personal a thinkr:RelationshipType, owl:NamedIndividual ;
    skos:prefLabel "Personal"@en .

thinkr:RelationshipType.Academic a thinkr:RelationshipType, owl:NamedIndividual ;
    skos:prefLabel "Academic"@en .

thinkr:RelationshipType.Legal a thinkr:RelationshipType, owl:NamedIndividual ;
    skos:prefLabel "Legal"@en .

thinkr:hasRelationshipType a owl:ObjectProperty ;
    rdfs:domain thinkr:Relationship ;
    rdfs:range thinkr:RelationshipType ;
    skos:prefLabel "has relationship type"@en .

thinkr:hasSubject a owl:ObjectProperty ;
    rdfs:domain thinkr:Relationship ;
    skos:comment "Explicitly names the relationship's OWN subject, not just its target (hasObject) — makes each Relationship individual a fully self-contained statement, not requiring a reverse lookup through hasPersonalRelationship to know whose relationship this is. Mirrors LinkNote's aboutSubject/aboutObject shape without directly reusing those (domain-restricted to LinkNote specifically)."@en ;
    skos:prefLabel "has subject"@en .

tgs:Person.NateHagens a thinkr:Person, owl:NamedIndividual ;
    skos:prefLabel "Nate Hagens"@en ;
    rdfs:comment "The graph's primary subject — this individual was notably absent until 2026-07-11 despite the entire graph being organized around his framework. NO owl:sameAs: verified 2026-07-11 he has no genuine Wikipedia page (the only hits are EverybodyWiki, not real Wikipedia, and an unrelated Wikidata entry Q51905132 for a different person entirely, 'Nathan A Hagen,' an ORCID-linked researcher with no connection to energy/TGS — confirmed via search, not assumed). Credentials (per the publications/credentials CV scope, not full employment history): PhD in Natural Resources, University of Vermont; Master's in Finance with Honors, University of Chicago Booth School of Business. Pre-TGS career: VP at Salomon Brothers and Lehman Brothers, President of Sanctuary Asset Management, before leaving Wall Street circa 2002-2004. TEACHING, genuine tense conflict between sources as of 2026-07-11 — his own site (natehagens.com/about2) says PAST tense, 'For eight years, Nate taught Reality 101, an honors course at the University of Minnesota'; other sources (RateMyProfessors, Resilience.org) use PRESENT tense. Not resolved either way, flagged honestly rather than guessed. 'Professor' title itself is informal/student usage (RateMyProfessors) — his own bio consistently says 'taught'/'teaches,' never asserts the formal rank. tgs:Work.RealityBlind was the course's primary text (confirmed via a LinkedIn post from Nate himself)."@en ;
    foaf:givenName "Nathan"@en ;
    foaf:familyName "Hagens"@en ;
    skos:scopeNote "Commonly known as 'Nate' (see skos:prefLabel) — 'Nathan' confirmed as his fuller given name via his own X handle, @NJHagens = Nathan John Hagens. Deliberately not resolving which form foaf:givenName 'should' hold here — flagging the real ambiguity rather than silently picking one, same as the deferred firstName/lastName backlog item."@en ;
    dbo:birthDate "1969"^^xsd:gYear ;
    foaf:homepage 
        <https://www.natehagens.com/>, 
        <https://natehagens.substack.com/>, 
        <https://www.linkedin.com/in/nate-hagens-004810b/> ;
    skos:scopeNote "foaf:homepage deliberately does NOT include thegreatsimplification.com or its YouTube channel — those arguably belong to TGS THE SHOW as its own entity (not currently modeled at all, same real gap as ISEOF/his employer, also unmodeled despite being confirmed real) rather than to Nate personally. Flagged, not resolved."@en ;
    thinkr:memberOf 
        tgs:Organization.TheOilDrum, 
        tgs:Organization.PostCarbonInstitute, 
        tgs:SchoolOfThought.PeakOilMovement, 
        tgs:AcademicInstitution.UniversityOfVermont, 
        tgs:AcademicInstitution.UniversityOfChicago, 
        tgs:AcademicInstitution.UniversityOfMinnesota ;
    thinkr:hasTGSRole 
        thinkr:ProfessionalRole.Educator, 
        thinkr:ProfessionalRole.InstituteExecutive, 
        thinkr:ProfessionalRole.Blogger, 
        thinkr:ProfessionalRole.Author ;
    thinkr:hasPersonalRelationship
        tgs:Relationship.NateHagens_MatthewMonahan,
        tgs:Relationship.NateHagens_IainMcGilchrist,
        tgs:Relationship.NateHagens_DanielSchmachtenberger .

# --- Matthew Monahan: RECIPROCAL — roles flip between the two interactions ---
tgs:Relationship.NateHagens_MatthewMonahan a thinkr:Relationship, owl:NamedIndividual ;
    thinkr:hasSubject tgs:Person.NateHagens ;
    thinkr:hasObject tgs:Person.MatthewMonahan ;
    thinkr:hasRelationshipType thinkr:RelationshipType.Professional ;
    skos:prefLabel "Nate Hagens' relationship with Matthew Monahan"@en ;
    thinkr:hasInteraction
        [ a thinkr:PodcastAppearance ;
          thinkr:role thinkr:InteractionRole.Host ;
          thinkr:episode tgs:Interview.TGS_226_CanMoneyServeLife ;
          thinkr:date "2026-06-29"^^xsd:date ],
        [ a thinkr:PodcastAppearance ;
          thinkr:role thinkr:InteractionRole.Guest ;
          thinkr:showName "The Regeneration Will Be Funded"@en ;
          thinkr:hostedBy tgs:Person.MatthewMonahan ;
          skos:scopeNote "Reciprocal appearance, roles reversed from the TGS episode above — confirmed via search 2026-07-11, exact date not independently pinned down."@en ] .

# --- Iain McGilchrist: THREE separate instances, same role each time ---
tgs:Relationship.NateHagens_IainMcGilchrist a thinkr:Relationship, owl:NamedIndividual ;
    thinkr:hasSubject tgs:Person.NateHagens ;
    thinkr:hasObject tgs:Person.IainMcGilchrist ;
    thinkr:hasRelationshipType thinkr:RelationshipType.Professional ;
    skos:prefLabel "Nate Hagens' relationship with Iain McGilchrist"@en ;
    thinkr:hasInteraction
        [ a thinkr:PodcastAppearance ;
          thinkr:role thinkr:InteractionRole.Host ;
          thinkr:episode tgs:Interview.TGS_85_WisdomNatureAndTheBrain ;
          thinkr:date "2023-07-13"^^xsd:date ],
        [ a thinkr:PodcastAppearance ;
          thinkr:role thinkr:InteractionRole.Host ;
          thinkr:episode tgs:Interview.TGS_165_WisdomOverPower ;
          thinkr:date "2025-01-02"^^xsd:date ],
        [ a thinkr:PodcastAppearance ;
          thinkr:role thinkr:InteractionRole.Host ;
          thinkr:episode tgs:Interview.TGS_217_WisdomInAWorldInCrisis ;
          thinkr:date "2026-03-24"^^xsd:date ] .

# --- Daniel Schmachtenberger: 3 confirmed of a likely-larger real total ---
tgs:Relationship.NateHagens_DanielSchmachtenberger a thinkr:Relationship, owl:NamedIndividual ;
    thinkr:hasSubject tgs:Person.NateHagens ;
    thinkr:hasObject tgs:Person.DanielSchmachtenberger ;
    thinkr:hasRelationshipType thinkr:RelationshipType.Professional ;
    skos:prefLabel "Nate Hagens' relationship with Daniel Schmachtenberger"@en ;
    skos:scopeNote "One source describes 'half a dozen' appearances — only 3 specific episodes individually confirmed/modeled as of 2026-07-11. This scopeNote itself demonstrates the pattern: honest about incompleteness at the relationship level, not just per-interaction."@en ;
    thinkr:hasInteraction
        [ a thinkr:PodcastAppearance ;
          thinkr:role thinkr:InteractionRole.Host ;
          thinkr:episode tgs:Interview.TGS_5_BendNotBreakPart1 ],
        [ a thinkr:PodcastAppearance ;
          thinkr:role thinkr:InteractionRole.Host ;
          thinkr:episode tgs:Interview.TGS_126_AVisionForBetterment ],
        [ a thinkr:PodcastAppearance ;
          thinkr:role thinkr:InteractionRole.Host ;
          thinkr:episode tgs:Interview.TGS_132_WideBoundaryImpactsOfAI ] .

# --- Test case: Nate's academic relationships genuinely need MULTIPLE types
# at once — this is real, not a hypothetical stress test. Teaching Reality
# 101 is both an Academic fact AND (per his own bio's "taught," implying a
# formal/paid role) a Professional one simultaneously. ---
tgs:Relationship.NateHagens_UniversityOfMinnesota a thinkr:Relationship, owl:NamedIndividual ;
    thinkr:hasSubject tgs:Person.NateHagens ;
    thinkr:hasObject tgs:AcademicInstitution.UniversityOfMinnesota ;
    thinkr:hasRelationshipType thinkr:RelationshipType.Academic, thinkr:RelationshipType.Professional ;
    skos:prefLabel "Nate Hagens' relationship with University of Minnesota"@en ;
    skos:scopeNote "Both Academic (teaching an honors course) AND Professional (a formal role) simultaneously — confirmed via live query this correctly returns BOTH types, not just one, proving the multi-valued design actually works rather than just looking plausible on paper."@en .

# ============================================================
# TESTED QUERIES (all confirmed working):
#
# 1. Interaction counts per relationship:
#      Iain McGilchrist: 3, Daniel Schmachtenberger: 3, Matthew Monahan: 2
#
# 2. Role-reversal detection (find every case where Nate was the GUEST,
#    not the host) — correctly surfaced exactly one:
#      "The Regeneration Will Be Funded"
#
# 3. Full chronological interaction history for one relationship, joined
#    against the REAL episodes.ttl for actual episode titles:
#      2023-07-13: Wisdom, Nature, and the Brain
#      2025-01-02: Wisdom Over Power: Why Contemplation & Wonder...
#      2026-03-24: Wisdom in a World in Crisis
#
# 4. Multi-valued RelationshipType — the UMN relationship correctly
#    returns BOTH "Professional" and "Academic" as separate result rows,
#    confirming the multi-valued design works, not just parses.
# ============================================================
