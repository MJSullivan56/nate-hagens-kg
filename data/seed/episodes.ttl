@prefix tgs:   <http://example.org/tgs#> .
@prefix thinkr: <http://example.org/thinkr#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix dcmitype: <http://purl.org/dc/dcmitype/> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/tgs#> a owl:Ontology ;
    owl:imports <http://example.org/thinkr#> ;
    rdfs:comment "Imports tgs-core for Protege compatibility — editing this file alone will resolve thinkr: classes/properties via the catalog file."@en .

#############################################
# thinkr:Episode — promoted out of tgs-core.ttl on 2026-07-11, its first
# real instances. Declared since the very first schema draft, zero
# instances the whole time until this: making explicit HOW three already-
# bootstrapped guests (Monahan, McGilchrist, Schmachtenberger) directly
# relate to tgs:Human.NateHagens, rather than leaving it implicit via
# thinkr:PersonEntityType.Guest alone (which never said whose guest they
# were — a real gap, matters once a second thinker's graph exists).
# Simple direct triples, not LinkNote/Evidence — these are well-documented,
# uncontested facts (confirmed via transcript excerpts / episode metadata),
# not interpretive claims needing confidence tracking.
# SUPERSEDED same day: originally used bare dct:creator/dct:contributor —
# too coarse once movies/books/TED talks etc. enter the picture (Nate is
# host+producer+interviewer, not just generically "creator"; a guest is
# semantically distinct from a generic "contributor"). Replaced with
# thinkr:hasHost/hasGuest, both declared in tgs-core.ttl as
# rdfs:subPropertyOf dcterms:creator/dcterms:contributor respectively —
# not co-asserted alongside the originals, same precedent as
# hasPersonEntityType superseding the bare hasNamedEntityType usage.
#
# TARGET SHAPE fleshed out 2026-07-11 for the 4 episodes with fully
# confirmed data (226, 85, 165, 217) — dct:created (recording date) vs
# dct:issued (publish date) are genuinely different facts, confirmed
# different for every episode checked; dct:subject reuses this graph's
# existing Subject taxonomy directly, matching the site's own subject
# tags where confirmed; thinkr:hasCanonicalSource/hasReplay/hasTranscript
# (all declared in tgs-core.ttl) replace the flatter dct:source-for-
# everything approach — canonical page, watch/listen link(s), and text
# transcript are three genuinely different things.
# The 3 Schmachtenberger episodes (5, 126, 132) are deliberately NOT yet
# fleshed out to this same depth — no confirmed data exists for them as
# of this writing, and this project doesn't fabricate structured facts
# to fill a template. Flesh out only once actually verified.
#############################################

thinkr:Episode a owl:Class ;
    rdfs:comment "A Great Simplification podcast episode or Frankly video."@en ;
    rdfs:subClassOf thinkr:Work ;
    skos:scopeNote "Narrower than thinkr:Work: specifically a TGS podcast episode or Frankly video, not a book/essay/report."@en ;
    skos:prefLabel "Podcast Episode"@en .

tgs:Interview.TGS_226_CanMoneyServeLife a thinkr:Episode, owl:NamedIndividual ;
    thinkr:hasEpisodeType thinkr:EpisodeType.Interview ;
    skos:prefLabel "Can Money Serve Life? How to Fund Communities Doing the Real Work"@en ;
    rdfs:comment "Note: Nate also appeared as GUEST on Matthew Monahan's own show 'The Regeneration Will Be Funded' (Ma Earth), a reciprocal cross-appearance — confirmed 2026-07-11, not modeled as a thinkr:Episode since that's a different show, out of this class's scope."@en ;
    dct:created "2026-06-29"^^xsd:date ;
    dct:issued "2026-07-08"^^xsd:date ;
    thinkr:discusses tgs:Concept.MoneyAsClaimOnEnergy ;
    dct:subject tgs:Subject.EconomicsAndMonetary ;
    thinkr:hasHost tgs:Persona.NateHagens ;
    thinkr:hasGuest tgs:Persona.MatthewMonahan ;
    thinkr:hasCanonicalSource <https://www.thegreatsimplification.com/episode/226-matthew-monahan> ;
    thinkr:hasReplay <https://youtu.be/yoJPgx2VlRQ>, <https://open.spotify.com/episode/2L2mSUkikXU72yfwuvldRK> ;
    thinkr:hasTranscript <https://www.thegreatsimplification.com/wp-content/uploads/2026/07/TGS-226-Matthew-Monahan-Transcript.docx.pdf> .

