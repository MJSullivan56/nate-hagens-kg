@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix dcmitype: <http://purl.org/dc/dcmitype/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix thinkr: <http://example.org/thinkr#> .

<http://example.org/thinkr#> a owl:Ontology ;
    rdfs:comment "TGS-core: reusable ontology (classes, properties, supporting-class instances) shared across any thinker's knowledge graph built on this pattern."@en .

thinkr:aboutObject a owl:ObjectProperty ;
    rdfs:domain thinkr:LinkNote ;
    skos:prefLabel "about object"@en .

thinkr:aboutSource a owl:ObjectProperty ;
    rdfs:comment "OPTIONAL. Absent when the Evidence is direct curator/maintainer reasoning rather than a citation to an external publication — such Evidence defaults to thinkr:ReliabilityType.Reputable for aggregation purposes (see that individual's definition)."@en ;
    rdfs:domain thinkr:Evidence ;
    rdfs:range thinkr:Source ;
    skos:prefLabel "about source"@en .

thinkr:aboutSubject a owl:ObjectProperty ;
    rdfs:domain thinkr:LinkNote ;
    skos:prefLabel "about subject"@en .

thinkr:appliesTo a owl:ObjectProperty ;
    rdfs:comment "For activists/practitioners rather than philosophers: this person's work is a concrete instance of the concept (e.g. MLK's organizing as an example of collective-action dynamics discussed under a TGS concept)."@en ;
    rdfs:domain thinkr:Persona ;
    rdfs:range thinkr:Concept ;
    skos:scopeNote "DOMAIN CHANGED 2026-07-14 (Batch 5 of the Persona-centered refactor): was thinkr:Human, moved to thinkr:Persona, per MJSullivan's explicit approval — same reasoning as every other Concept-facing property migrated in this batch. The single existing instance (MLK->GrowthImperative, linknotes.ttl) was already pointing at tgs:Persona.MartinLutherKingJr by the time this domain was fixed — caught as a side effect of an earlier blanket Human->Persona text replacement in that file, not a separate deliberate step; this declaration just brings the schema in line with what the data already said."@en ;
    skos:prefLabel "provides real-world example of"@en .

thinkr:calculatedConfidence a owl:ObjectProperty ;
    rdfs:comment "DERIVED — computed from a LinkNote's Evidence set by scripts/compute_confidence.py. Never hand-write this value into a TTL file; it will drift out of sync with its own evidence. Re-run the compute script after adding/editing any Evidence."@en ;
    rdfs:domain thinkr:LinkNote ;
    rdfs:range thinkr:ConfidenceType ;
    skos:prefLabel "calculated confidence"@en .

thinkr:confidence a owl:ObjectProperty ;
    rdfs:comment "Has THIS piece of evidence been human-reviewed? Points to thinkr:ConfidenceType.Curated or .Candidate only (the other two values, Corroborated/Disputed, are LinkNote-only via thinkr:calculatedConfidence). Domain history: originally xsd:string on thinkr:Concept (wrong), then an enumerated object property on thinkr:LinkNote directly (better, but conflated the assertion with its evidence), now correctly on thinkr:Evidence as part of the Evidence/Source provenance model."@en ;
    rdfs:domain thinkr:Evidence ;
    rdfs:range thinkr:ConfidenceType .

thinkr:contrastsWith a owl:ObjectProperty ;
    rdfs:comment "Useful tension or disagreement worth surfacing to a learner, not just agreement."@en ;
    rdfs:subPropertyOf thinkr:relatesTo ;
    skos:scopeNote "Narrower than thinkr:relatesTo: specifically a useful tension or disagreement, not any relation — does not imply influence in either direction."@en ;
    skos:prefLabel "contrasts with"@en .

thinkr:definedIn a owl:ObjectProperty ;
    rdfs:domain thinkr:Concept ;
    rdfs:range thinkr:Work ;
    skos:prefLabel "primarily defined in"@en .

thinkr:discussedIn a owl:ObjectProperty ;
    rdfs:domain thinkr:Concept ;
    rdfs:range thinkr:Episode ;
    skos:prefLabel "discussed in episode"@en .

thinkr:echoesIdeaOf a owl:ObjectProperty ;
    rdfs:comment "The TGS concept independently converges on / restates an idea this person is known for. No claim of direct influence."@en ;
    rdfs:domain thinkr:Concept ;
    rdfs:range thinkr:Persona ;
    rdfs:subPropertyOf thinkr:relatesTo ;
    skos:scopeNote "Narrower than thinkr:relatesTo: specifically independent convergence on a similar idea — explicitly NOT a claim of direct influence, see thinkr:influencedBy for that distinct, stronger case. RANGE CHANGED 2026-07-14 (Batch 5 of the Persona-centered refactor, docs/sidecar-cleanup-handoff.md) from thinkr:Human to thinkr:Persona: this is the graph's actual core mechanism — every Concept->thinker connection is fundamentally about that person's PUBLIC INTELLECTUAL ROLE, never a private biographical fact. All existing echoesIdeaOf triples (linknotes.ttl) migrated Human->Persona in the same pass."@en ;
    skos:prefLabel "echoes idea of"@en .

thinkr:evidencePolarity a owl:ObjectProperty ;
    rdfs:domain thinkr:Evidence ;
    rdfs:range thinkr:PolarityType ;
    skos:prefLabel "evidence polarity"@en .

thinkr:hasEvidence a owl:ObjectProperty ;
    rdfs:domain thinkr:LinkNote ;
    rdfs:range thinkr:Evidence ;
    skos:prefLabel "has evidence"@en .

thinkr:influencedBy a owl:ObjectProperty ;
    rdfs:comment "Direct, citable influence — Hagens has referenced this person/school explicitly in developing the concept."@en ;
    rdfs:domain thinkr:Concept ;
    rdfs:range [ owl:unionOf ( thinkr:Persona thinkr:SchoolOfThought thinkr:Organization thinkr:AcademicInstitution ) ] ;
    rdfs:subPropertyOf thinkr:relatesTo ;
    skos:scopeNote "Narrower than thinkr:relatesTo: specifically direct, citable influence (Hagens referenced this source explicitly) — see thinkr:echoesIdeaOf for the weaker, independent-convergence case. RANGE CHANGED 2026-07-14 (Batch 5 of the Persona-centered refactor): Human replaced with Persona in the union — same reasoning as echoesIdeaOf. All existing influencedBy triples (linknotes.ttl) migrated Human->Persona in the same pass."@en ;
    skos:prefLabel "influenced by"@en .

thinkr:memberOf a owl:ObjectProperty ;
    rdfs:domain thinkr:Human ;
    rdfs:range [ a owl:Class ; owl:unionOf ( thinkr:SchoolOfThought thinkr:Organization thinkr:AcademicInstitution ) ] ;
    skos:comment "Range widened 2026-07-11 when thinkr:School was split into SchoolOfThought/Organization/AcademicInstitution — see the three class declarations below for the reasoning."@en ;
    skos:prefLabel "member of / associated with"@en .

thinkr:reliabilityTier a owl:ObjectProperty ;
    rdfs:domain thinkr:Source ;
    rdfs:range thinkr:ReliabilityType ;
    skos:prefLabel "reliability tier"@en .

thinkr:convergesWith a owl:ObjectProperty, owl:SymmetricProperty ;
    rdfs:comment "Independently-developed ideas/frameworks converging on similar conclusions, with NO claimed causal lineage or direct influence — distinct from influencedBy/echoesIdeaOf, which both imply direction. Formally symmetric per OWL semantics, BUT this project's query tooling doesn't run a reasoner (same reason owl:NamedIndividual is asserted explicitly everywhere rather than relied on via subclass inference) — so BOTH directions must be explicitly asserted as real triples, or querying from the 'other' side returns nothing. Verified empirically 2026-07-11: querying tgs:SchoolOfThought.DoughnutEconomics thinkr:convergesWith ?x returned zero results until the reverse triple was added by hand, despite the forward direction being asserted and the property being formally symmetric. First used for tgs:Concept.Overshoot <-> tgs:SchoolOfThought.DoughnutEconomics."@en ;
    skos:prefLabel "converges with"@en .

thinkr:NamedEntity a owl:Class ;
    rdfs:comment "Superclass for anything that can be surfaced via the NER pipeline (extraction/index_named_entities.py) and formally modeled in the graph. thinkr:Human is currently the only subclass — deliberately left room for others (e.g. an Organization class) to join later without redesigning this. Plain owl:Class, not SKOS — added 2026-07-11 at MJSullivan's direction, correcting an earlier proposal to use SKOS for the same purpose."@en ;
    skos:prefLabel "Named Entity"@en .

thinkr:NamedEntityType a owl:Class ;
    rdfs:comment "ABSTRACT top-level category class — restructured 2026-07-11 per MJSullivan: each thinkr:NamedEntity subclass gets its OWN more specific categorization as a subclass of this one (e.g. thinkr:PersonEntityType for thinkr:Human), rather than one flat enumeration shared across every subclass. Mirrors the class hierarchy: thinkr:NamedEntity -> thinkr:Human is paralleled by thinkr:NamedEntityType -> thinkr:PersonEntityType. A future Organization subclass would get its own thinkr:OrganizationEntityType sibling, not reuse Person's categories."@en ;
    skos:prefLabel "Named Entity Type"@en .

thinkr:hasNamedEntityType a owl:ObjectProperty ;
    rdfs:domain thinkr:NamedEntity ;
    rdfs:range thinkr:NamedEntityType ;
    rdfs:comment "GENERAL, top-level property — in practice, use a subclass-specific subproperty instead (e.g. thinkr:hasPersonEntityType for a thinkr:Human). This property exists mainly for uniform querying across ALL NamedEntity subclasses at once, once more than one exists."@en ;
    skos:prefLabel "has named entity type"@en .

thinkr:hasPersonEntityType a owl:ObjectProperty ;
    rdfs:subPropertyOf thinkr:hasNamedEntityType ;
    skos:scopeNote "Narrower than thinkr:hasNamedEntityType: the property to actually use for thinkr:Persona individuals in practice."@en ;
    rdfs:domain thinkr:Persona ;
    rdfs:range thinkr:PersonEntityType ;
    rdfs:comment "The property to actually USE for Persona individuals — subPropertyOf the general thinkr:hasNamedEntityType. Same explicit-typing caveat as elsewhere in this project: rdfs:subPropertyOf won't make a hasPersonEntityType triple automatically queryable via hasNamedEntityType without a reasoner (this project's tooling doesn't run one) — assert both explicitly if a query needs to work at the general level. DOMAIN CHANGED 2026-07-14 (Batch 3 of the Persona-centered refactor, docs/sidecar-cleanup-handoff.md): was thinkr:Human, moved to thinkr:Persona — being tagged Guest/Contributor is a fact about someone's public relationship to TGS, the same category of fact as hasHost/hasGuest (migrated in Batch 2), not a private biographical fact. Flagged as an open question in personas.ttl's Batch 1 comment ('revisit once Batch 3 clarifies') and resolved here."@en ;
    skos:prefLabel "has person entity type"@en .

thinkr:aboutEntity a owl:ObjectProperty ;
    rdfs:domain thinkr:CrosswalkNote ;
    rdfs:range thinkr:NamedEntity ;
    rdfs:comment "The Person/School/Work etc. this crosswalk note documents an external mapping for."@en ;
    skos:prefLabel "about entity"@en .

thinkr:aboutExternalURI a owl:ObjectProperty ;
    rdfs:domain thinkr:CrosswalkNote ;
    rdfs:comment "The external URI (DBpedia/Wikidata resource) this crosswalk note documents — mirrors the actual owl:sameAs triple's object, kept direct and reasoner-compatible rather than reified."@en ;
    skos:prefLabel "about external URI"@en .

thinkr:crosswalkSource a owl:ObjectProperty ;
    rdfs:domain thinkr:CrosswalkNote ;
    rdfs:range thinkr:CrosswalkSource ;
    skos:prefLabel "crosswalk source"@en .

thinkr:verifiedOn a owl:DatatypeProperty ;
    rdfs:domain thinkr:CrosswalkNote ;
    rdfs:range xsd:date ;
    skos:prefLabel "verified on"@en .

thinkr:hasEpisodeType a owl:ObjectProperty ;
    rdfs:domain thinkr:Episode ;
    rdfs:range thinkr:EpisodeType ;
    skos:prefLabel "has episode type"@en .

thinkr:hasCanonicalSource a owl:ObjectProperty ;
    rdfs:subPropertyOf dcterms:source ;
    rdfs:domain thinkr:Episode ;
    skos:scopeNote "The canonical page for this Episode — expected cardinality of exactly one, unlike the general dct:source (still used elsewhere in this graph, e.g. Work.CaliforniaDoughnutReport2025, with no such cardinality expectation). subPropertyOf lets this stay a genuine dct:source for anything that reads it generically, while carrying a narrower, Episode-specific meaning here — a scopeNote directly on dct:source itself would incorrectly apply globally to every other use of that property in this graph."@en .

thinkr:discusses a owl:ObjectProperty ;
    rdfs:domain thinkr:Episode ;
    rdfs:range thinkr:Concept ;
    skos:comment "Which Concept(s) an Episode actually discusses — closes the gap identified 2026-07-13 (zero Episode->Concept links existed before this). Named 'discusses' with Episode as subject, matching every other Episode property's directionality (hasHost/hasGuest/hasCanonicalSource/dct:subject/dct:created all have Episode as subject) — deliberately NOT 'thinkr:discussedIn' as originally sketched in extraction/README.md, which would have had Concept as subject, facing the opposite direction from its siblings."@en ;
    skos:prefLabel "discusses"@en .

thinkr:hasReplay a owl:ObjectProperty ;
    rdfs:domain thinkr:Work ;
    skos:scopeNote "A link to watch/listen to a replay (YouTube, Spotify, etc.) — multi-valued, one triple per platform. Domain deliberately kept at thinkr:Work, not narrowed to Episode: some future Work subtypes (e.g. an audiobook) could plausibly have a replay too. Many Work subtypes (Book, WhitePaper, PhDThesis) genuinely won't — that's a fact about the specific instance, not something enforced structurally."@en .

thinkr:hasTranscript a owl:ObjectProperty ;
    rdfs:domain thinkr:Work ;
    skos:scopeNote "A link to a text transcript, distinct from thinkr:hasReplay (audio/video) and thinkr:hasCanonicalSource (the page about the content, not the content itself)."@en .

thinkr:hasProfessionalRole a owl:ObjectProperty ;
    rdfs:domain thinkr:Persona ;
    rdfs:range thinkr:ProfessionalRole ;
    skos:scopeNote "General-purpose grouping, NOT provenance-tracked — unlike memberOf/AffiliationNote (still pending its own design, see docs/sidecar-cleanup-handoff.md), this doesn't claim when/how the role was verified, just that it's a useful high-level label. DOMAIN CHANGED 2026-07-14 (Batch 3 of the Persona-centered refactor): was thinkr:Human, moved to thinkr:Persona — professional/public role tags are the same category of fact as hasPersonEntityType and hasHost/hasGuest, migrated in the same pass for consistency."@en .

thinkr:hasTGSRole a owl:ObjectProperty ;
    rdfs:subPropertyOf thinkr:hasProfessionalRole ;
    rdfs:range [ a owl:Class ; owl:oneOf (
        thinkr:ProfessionalRole.Educator
        thinkr:ProfessionalRole.InstituteExecutive
        thinkr:ProfessionalRole.Blogger
        thinkr:ProfessionalRole.Author
    ) ] ;
    skos:scopeNote "Curated subset of thinkr:ProfessionalRole specifically useful for people in the TGS orbit. The range restriction is DOCUMENTATION ONLY, not enforced — this project currently has exactly two editors (MJSullivan and Claude), so a manually-respected convention is sufficient; would need a real validation script if that ever changes."@en .

#############################################
# thinkr:Relationship family — formally adopted 2026-07-12 from
# relationship_prototype.ttl (originally built as a sandbox exercise,
# discovered to have been sitting in data/seed/ the whole time, formally
# promoted rather than removed per MJSullivan's explicit decision).
# thinkr:Relationship itself + its instances live in relationships.ttl
# (real instances already exist, same "one class one file" promotion
# rule as Work/Source/Episode). Everything below is supporting
# schema/category infrastructure that belongs in tgs-core.ttl.
#############################################

thinkr:hasRelationshipType a owl:ObjectProperty ;
    rdfs:domain thinkr:Relationship ;
    rdfs:range thinkr:RelationshipType ;
    skos:prefLabel "has relationship type"@en .

thinkr:hasSubject a owl:ObjectProperty ;
    rdfs:domain thinkr:Relationship ;
    skos:comment "Explicitly names the relationship's OWN subject, not just its target (hasObject) — makes each Relationship individual a fully self-contained statement, not requiring a reverse lookup through hasPersonalRelationship to know whose relationship this is. Mirrors LinkNote's aboutSubject/aboutObject shape without directly reusing those (domain-restricted to LinkNote specifically)."@en ;
    skos:prefLabel "has subject"@en .

thinkr:hasObject a owl:ObjectProperty ;
    rdfs:domain thinkr:Relationship ;
    skos:comment "The other party in the Relationship — paired with hasSubject for full self-containment."@en ;
    skos:prefLabel "has object"@en .

thinkr:hasPersonalRelationship a owl:ObjectProperty ;
    rdfs:domain thinkr:Persona ;
    rdfs:range thinkr:Relationship ;
    skos:comment "Links a Persona to their Relationship individuals. Named specifically (not just 'hasRelationship') matching the editorial sketch's original hasPersonalRelationship/hasOrganizationRelationship/hasSchoolRelationship family — only this one built so far, the others deliberately not invented ahead of real need. DOMAIN CHANGED 2026-07-14 (Batch 3 of the Persona-centered refactor, docs/sidecar-cleanup-handoff.md) from thinkr:Human to thinkr:Persona: every Relationship a Human party to it now runs through their Persona instead, per the final settled principle that Human is a pure leaf node reachable only via thinkr:actsThrough."@en ;
    skos:prefLabel "has personal relationship"@en .

thinkr:PodcastAppearance a owl:Class ;
    rdfs:comment "A single interaction instance within a Relationship — nested as a blank node under hasInteraction, deliberately unnamed (solves the multi-instance naming problem: McGilchrist's 3 separate appearances needed zero additional naming decisions)."@en ;
    skos:prefLabel "Podcast Appearance"@en .

thinkr:hasInteraction a owl:ObjectProperty ;
    rdfs:domain thinkr:Relationship ;
    rdfs:range thinkr:PodcastAppearance ;
    skos:comment "Multi-valued — one triple per interaction instance, each a separate blank node."@en ;
    skos:prefLabel "has interaction"@en .

thinkr:subjectRole a owl:ObjectProperty ;
    rdfs:domain thinkr:PodcastAppearance ;
    rdfs:range thinkr:InteractionRole ;
    rdfs:comment "The role played by the containing Relationship's hasSubject in THIS SPECIFIC appearance — explicit, not inferred."@en ;
    skos:prefLabel "subject role"@en .

thinkr:objectRole a owl:ObjectProperty ;
    rdfs:domain thinkr:PodcastAppearance ;
    rdfs:range thinkr:InteractionRole ;
    rdfs:comment "The role played by the containing Relationship's hasObject in THIS SPECIFIC appearance — explicit, not inferred. Together with subjectRole, SUPERSEDES thinkr:role (retired 2026-07-14, Batch 3 of the Persona-centered refactor) — the old singular property only ever captured one party's role and left the other permanently implicit, which broke the moment an interaction wasn't a clean host/guest binary (co-host, moderator, panelist). Proven concretely on the reciprocal Matthew Monahan case: without this split there was no clean way to distinguish 'Nate hosted him on TGS' from 'he hosted Nate on his own show' except by which property happened to be populated."@en ;
    skos:prefLabel "object role"@en .

thinkr:episode a owl:ObjectProperty ;
    rdfs:domain thinkr:PodcastAppearance ;
    rdfs:range thinkr:Episode ;
    skos:comment "Used when the appearance is a real, already-modeled Episode individual. For appearances on OTHER shows not modeled in this graph, use showName/hostedBy instead (see the reciprocal Matthew Monahan case)."@en ;
    skos:prefLabel "episode"@en .

thinkr:showName a owl:DatatypeProperty ;
    rdfs:domain thinkr:PodcastAppearance ;
    skos:comment "The name of a show NOT modeled as its own Episode individual in this graph — e.g. Nate's reciprocal guest appearance on Matthew Monahan's own show."@en ;
    skos:prefLabel "show name"@en .

thinkr:hostedBy a owl:ObjectProperty ;
    rdfs:domain thinkr:PodcastAppearance ;
    rdfs:range thinkr:Human ;
    skos:comment "Who hosted this specific appearance — used together with showName for appearances on shows not otherwise modeled in this graph."@en ;
    skos:prefLabel "hosted by"@en .

thinkr:hasHost a owl:ObjectProperty ;
    rdfs:subPropertyOf dcterms:creator ;
    rdfs:domain thinkr:Work ;
    rdfs:range thinkr:Persona ;
    skos:scopeNote "The person who hosts/leads this Work — distinct from dct:creator's broader sense, which for other Work subtypes might mean author, director, etc. instead. Same reasoner caveat as thinkr:hasPersonEntityType: doesn't make the fact queryable via bare dct:creator without a reasoner. RANGE ADDED 2026-07-14 (Batch 2 of the Persona-centered refactor, docs/sidecar-cleanup-handoff.md): being a host is a public-facing fact conferred by the appearance itself, which belongs to Persona, not Human directly — same reasoning as hasGuest below. All 14 existing hasHost triples migrated Human->Persona in the same pass (episodes.ttl)."@en .

thinkr:hasGuest a owl:ObjectProperty ;
    rdfs:subPropertyOf dcterms:contributor ;
    rdfs:domain thinkr:Work ;
    rdfs:range thinkr:Persona ;
    skos:scopeNote "A person being interviewed/featured — distinct from dct:contributor's broader sense (editor, co-author, etc. for other Work subtypes). RANGE ADDED 2026-07-14 (Batch 2 of the Persona-centered refactor): even a MINIMAL Persona (identical name, zero distinguishing content, existing solely because the appearance happened) is sufficient — tested concretely in the 2026-07-13 escalation. All 11 existing hasGuest triples migrated Human->Persona in the same pass (episodes.ttl)."@en .

thinkr:Series a owl:Class ;
    rdfs:subClassOf thinkr:Work, dcmitype:Collection ;
    rdfs:comment "The overarching arc itself (e.g. 'How to Think About the Future'), distinct from any single installment. First instance added 2026-07-11 (Series.HowToThinkAboutTheFuture, with 3 stub Frankly installments) — no longer zero-instance."@en ;
    skos:scopeNote "Dual superclass, same pattern as thinkr:Human (foaf:Person + thinkr:NamedEntity): narrower than thinkr:Work in that it has real Work-like properties (title, host, potentially subject) — but a Series has no standalone content of its own (no replay, no transcript), which is exactly what dcmitype:Collection (an aggregation of resources, membership understood via description of the aggregation) captures and thinkr:Work alone does not. dct:isPartOf/dct:hasPart (used on each installment) are the DCMI-standard properties for exactly this relationship — Collection is their natural target type, not an arbitrary addition."@en ;
    skos:prefLabel "Series"@en .

thinkr:seriesPosition a owl:DatatypeProperty ;
    rdfs:domain thinkr:Work ;
    rdfs:range xsd:integer ;
    skos:scopeNote "Ordinal position within the thinkr:Series pointed to by dct:isPartOf on the same individual — e.g. 2 for Part 2. No Dublin Core term exists for this specifically, minted directly (unlike dct:references/dct:isPartOf, which are used as-is with no subproperty needed — both already carry the right generic meaning)."@en .

thinkr:relatesTo a owl:ObjectProperty ;
    rdfs:comment "Generic, loosely-typed link. Use a more specific property below when it fits."@en ;
    rdfs:domain thinkr:Concept ;
    rdfs:range [ owl:unionOf ( thinkr:Concept thinkr:Persona thinkr:SchoolOfThought thinkr:Organization thinkr:AcademicInstitution ) ] ;
    skos:scopeNote "RANGE CHANGED 2026-07-14 (Batch 5 of the Persona-centered refactor): Human replaced with Persona in the union — this is the parent property of contrastsWith (which has no range of its own), influencedBy, and echoesIdeaOf, all migrated in the same pass."@en ;
    skos:prefLabel "relates to"@en .

thinkr:Category a owl:Class ;
    rdfs:comment "A special class whose instances are enumerated and curated, used to further categorize instances of OTHER classes for more specificity — not a domain entity itself. Formalized 2026-07-11 per MJSullivan's exact definition, marking a pattern that was already implicit in ConfidenceType/ReliabilityType/PolarityType and just-built PersonEntityType. Classes are marked as Category via 'a thinkr:Category' (OWL punning — a class doubling as an instance of this meta-class), not rdfs:subClassOf, since Category-ness is a property of the CLASS itself, not something its own individuals (e.g. ConfidenceType.Curated) inherit. NOTE: thinkr:NamedEntityType is deliberately NOT marked Category — it has zero direct instances of its own (only its subclass PersonEntityType does), so it doesn't meet 'has enumerated curated instances' literally. It's an organizing abstraction, not a Category proper."@en ;
    skos:prefLabel "Category"@en .
