@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix tgs: <http://example.org/tgs#> .
@prefix thinkr: <http://example.org/thinkr#> .

<http://example.org/tgs#> a owl:Ontology ;
    owl:imports <http://example.org/thinkr#> ;
    rdfs:comment "Imports tgs-core for Protege compatibility — editing this file alone will resolve thinkr: classes/properties via the catalog file."@en .


tgs:Person.Aristotle a thinkr:Person,
        owl:NamedIndividual ;
    skos:prefLabel "Aristotle"@en .

tgs:Person.Buddha a thinkr:Person,
        owl:NamedIndividual ;
    skos:prefLabel "Gautama Buddha"@en .

tgs:Person.DanielKahneman a thinkr:Person,
        owl:NamedIndividual ;
    skos:prefLabel "Daniel Kahneman"@en .

tgs:Person.DennisMeadows a thinkr:Person,
        owl:NamedIndividual ;
    skos:prefLabel "Dennis Meadows"@en .

tgs:Person.DonellaMeadows a thinkr:Person,
        owl:NamedIndividual ;
    skos:prefLabel "Donella Meadows"@en .

tgs:Person.EOWilson a thinkr:Person,
        owl:NamedIndividual ;
    skos:prefLabel "E. O. Wilson"@en .

tgs:Person.ElinorOstrom a thinkr:Person,
        owl:NamedIndividual ;
    skos:prefLabel "Elinor Ostrom"@en .

tgs:Person.EmileDurkheim a thinkr:Person,
        owl:NamedIndividual ;
    skos:prefLabel "Émile Durkheim"@en .

tgs:Person.Epictetus a thinkr:Person,
        owl:NamedIndividual ;
    thinkr:memberOf tgs:School.Stoicism ;
    skos:prefLabel "Epictetus"@en .

tgs:Person.GregoryBateson a thinkr:Person,
        owl:NamedIndividual ;
    skos:prefLabel "Gregory Bateson"@en .

tgs:Person.IvanIllich a thinkr:Person,
        owl:NamedIndividual ;
    skos:prefLabel "Ivan Illich"@en .

tgs:Person.JosephTainter a thinkr:Person,
        owl:NamedIndividual ;
    skos:prefLabel "Joseph Tainter"@en .

tgs:Person.MKingHubbert a thinkr:Person,
        owl:NamedIndividual ;
    thinkr:memberOf tgs:School.PeakOilMovement ;
    skos:prefLabel "M. King Hubbert"@en .

tgs:Person.MarcusAurelius a thinkr:Person,
        owl:NamedIndividual ;
    thinkr:memberOf tgs:School.Stoicism ;
    skos:prefLabel "Marcus Aurelius"@en .

tgs:Person.MartinLutherKingJr a thinkr:Person,
        owl:NamedIndividual ;
    skos:prefLabel "Martin Luther King Jr."@en .

tgs:Person.RachelCarson a thinkr:Person,
        owl:NamedIndividual ;
    skos:prefLabel "Rachel Carson"@en .

tgs:Person.SigmundFreud a thinkr:Person,
        owl:NamedIndividual ;
    skos:prefLabel "Sigmund Freud"@en .

tgs:Person.WendellBerry a thinkr:Person,
        owl:NamedIndividual ;
    skos:prefLabel "Wendell Berry"@en .

tgs:Person.WilliamCatton a thinkr:Person,
        owl:NamedIndividual ;
    skos:prefLabel "William R. Catton Jr."@en .

tgs:Person.WilliamStanleyJevons a thinkr:Person,
        owl:NamedIndividual ;
    skos:prefLabel "William Stanley Jevons"@en .

thinkr:Person a owl:Class ;
    rdfs:comment "A philosopher, scientist, activist, or thinker being linked to a TGS concept."@en ;
    rdfs:subClassOf foaf:Person ;
    skos:prefLabel "Person"@en .

