@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix tgs: <http://example.org/tgs#> .
@prefix thinkr: <http://example.org/thinkr#> .

<http://example.org/tgs#> a owl:Ontology ;
    owl:imports <http://example.org/thinkr#> ;
    rdfs:comment "Imports tgs-core for Protege compatibility — editing this file alone will resolve thinkr: classes/properties via the catalog file."@en .


tgs:Concept.CarbonPulse a thinkr:Concept,
        owl:NamedIndividual ;
    dcterms:source <https://www.thegreatsimplification.com> ;
    dcterms:subject tgs:Subject.EROIAndEnergyQuality ;
    skos:definition "The one-time, temporary burst of high-density energy available to humanity via fossil fuels, framed as a short pulse on a geological timescale rather than a permanent baseline."@en ;
    skos:prefLabel "The Carbon Pulse"@en .

tgs:Concept.CircleOfTrustLocalism a thinkr:Concept,
        owl:NamedIndividual ;
    dcterms:source <https://www.thegreatsimplification.com> ;
    dcterms:subject tgs:Subject.CommunityAndResponse ;
    skos:definition "Hagens' emphasis on rebuilding smaller-scale, face-to-face community and local resource resilience as an adaptive response to declining energy surplus and institutional fragility."@en ;
    skos:prefLabel "Local Resilience / 'Circle of Trust'"@en ;
    thinkr:echoesIdeaOf tgs:Persona.ElinorOstrom .

tgs:Concept.ComplexityCollapse a thinkr:Concept,
        owl:NamedIndividual ;
    dcterms:source <https://www.thegreatsimplification.com> ;
    dcterms:subject tgs:Subject.OvershootAndLimits ;
    skos:definition "The idea that societies invest in increasing complexity (institutions, specialization, infrastructure) to solve problems, but complexity carries rising energy/resource costs with diminishing returns — eventually making collapse (a rapid loss of complexity) a rational, if painful, adaptive response rather than an aberration."@en ;
    skos:prefLabel "Complexity and Collapse"@en ;
    thinkr:influencedBy tgs:Persona.JosephTainter .

tgs:Concept.DiscountRatesAndPresentBias a thinkr:Concept,
        owl:NamedIndividual ;
    dcterms:source <https://www.thegreatsimplification.com> ;
    dcterms:subject tgs:Subject.BehavioralEconomicsAndCognition ;
    skos:definition "The behavioral and financial tendency to heavily undervalue future costs and benefits relative to present ones, which Hagens treats as a key mechanism by which markets and individuals systematically under-price long-term ecological risk."@en ;
    skos:prefLabel "Discount Rates / Present Bias"@en ;
    thinkr:echoesIdeaOf tgs:Persona.MarcusAurelius .

tgs:Concept.EROI a thinkr:Concept,
        owl:NamedIndividual ;
    dcterms:source <https://www.thegreatsimplification.com> ;
    dcterms:subject tgs:Subject.EROIAndEnergyQuality ;
    skos:definition "The ratio of energy delivered by an energy source to the energy required to extract/produce it; central to Hagens' argument that the quality, not just quantity, of energy sources matters for what a society can sustain."@en ;
    skos:prefLabel "EROI (Energy Return on Investment)"@en .

tgs:Concept.EnergyBlindness a thinkr:Concept,
        owl:NamedIndividual ;
    dcterms:source <https://www.thegreatsimplification.com> ;
    dcterms:subject tgs:Subject.EROIAndEnergyQuality ;
    skos:definition "The tendency of economics, policy, and everyday thinking to treat energy as a substitutable input abstracted into monetary terms, obscuring how dependent modern life is on cheap, concentrated, finite energy."@en ;
    skos:prefLabel "Energy Blindness"@en ;
    thinkr:contrastsWith tgs:Persona.Buddha ;
    thinkr:influencedBy tgs:Persona.ArtBerman .

tgs:Concept.EnergySlaves a thinkr:Concept,
        owl:NamedIndividual ;
    dcterms:source <https://www.thegreatsimplification.com> ;
    dcterms:subject tgs:Subject.EROIAndEnergyQuality ;
    skos:definition "A framing device measuring the work output of fossil-fuel energy in equivalent human labor-hours, to make the scale of energy subsidy to modern life viscerally graspable."@en ;
    skos:prefLabel "Energy Slaves"@en .

tgs:Concept.GreatSimplification a thinkr:Concept,
        owl:NamedIndividual ;
    dcterms:source <https://www.thegreatsimplification.com> ;
    dcterms:subject tgs:Subject.SystemsFrameworks ;
    skos:definition "Hagens' term for a coming, likely non-linear reduction in the complexity, energy throughput, and material consumption of global civilization, as fossil fuel surplus energy declines relative to what the economy has grown to expect."@en ;
    skos:prefLabel "The Great Simplification"@en .

tgs:Concept.GrowthImperative a thinkr:Concept,
        owl:NamedIndividual ;
    dcterms:source <https://www.thegreatsimplification.com> ;
    dcterms:subject tgs:Subject.MonetarySystemAndGrowth ;
    skos:definition "The structural requirement of debt-based monetary systems and compound interest for continual economic growth, which Hagens argues locks in ever-increasing energy/material throughput regardless of ecological limits."@en ;
    skos:prefLabel "The Growth Imperative"@en .

tgs:Concept.HumanPredicament a thinkr:Concept,
        owl:NamedIndividual ;
    dcterms:source <https://www.thegreatsimplification.com> ;
    dcterms:subject tgs:Subject.SystemsFrameworks ;
    skos:definition "Hagens' preferred framing over 'the climate problem' or 'the energy problem' — the interlocking set of ecological overshoot, energy decline, economic dependence on growth, and human behavioral wiring, treated as a single systemic predicament rather than a checklist of separate problems with separate solutions."@en ;
    skos:prefLabel "The Human Predicament"@en .

tgs:Concept.JevonsParadox a thinkr:Concept,
        owl:NamedIndividual ;
    dcterms:source <https://www.thegreatsimplification.com> ;
    dcterms:subject tgs:Subject.EROIAndEnergyQuality ;
    skos:definition "The observation that increases in efficiency of resource use often lead to increased total consumption of that resource rather than decreased, because efficiency lowers effective cost and expands use — a recurring theme in Hagens' skepticism toward efficiency-alone as a solution to overshoot."@en ;
    skos:prefLabel "Jevons Paradox"@en ;
    thinkr:influencedBy tgs:Persona.WilliamStanleyJevons .

tgs:Concept.LimitsToGrowth a thinkr:Concept,
        owl:NamedIndividual ;
    dcterms:source <https://www.thegreatsimplification.com> ;
    dcterms:subject tgs:Subject.OvershootAndLimits ;
    skos:definition "Reference to the 1972 Club of Rome-commissioned study modeling interactions between population, industrialization, pollution, food production, and resource depletion, projecting overshoot-and-decline dynamics on multi-decade timescales — a direct intellectual predecessor to Hagens' framework."@en ;
    skos:prefLabel "Limits to Growth"@en ;
    thinkr:influencedBy tgs:Persona.DennisMeadows, tgs:Persona.DonellaMeadows .

tgs:Concept.Metacrisis a thinkr:Concept,
        owl:NamedIndividual ;
    dcterms:source <https://www.thegreatsimplification.com> ;
    dcterms:subject tgs:Subject.SystemsFrameworks ;
    skos:definition "A term (shared with adjacent thinkers like Daniel Schmachtenberger) for the idea that today's separate crises — climate, biodiversity, inequality, political polarization, mental health — share common generative root causes rather than being independent problems."@en ;
    skos:prefLabel "Metacrisis"@en ;
    thinkr:influencedBy tgs:Persona.GregoryBateson .

tgs:Concept.MoneyAsClaimOnEnergy a thinkr:Concept,
        owl:NamedIndividual ;
    dcterms:source <https://www.thegreatsimplification.com> ;
    dcterms:subject tgs:Subject.MonetarySystemAndGrowth ;
    skos:definition "Hagens' framing of money not as wealth itself but as a social/legal claim on future energy and resources — meaning monetary growth (via debt, interest) implicitly presumes continued growth in real energy throughput, tying the Growth Imperative concept directly to biophysical limits rather than treating them as separate domains."@en ;
    skos:prefLabel "Money as a Claim on Future Energy"@en ;
    thinkr:echoesIdeaOf tgs:Persona.Aristotle .

tgs:Concept.Overshoot a thinkr:Concept,
        owl:NamedIndividual ;
    dcterms:source <https://www.thegreatsimplification.com> ;
    dcterms:subject tgs:Subject.OvershootAndLimits ;
    skos:definition "The condition of a population/economy consuming renewable and non-renewable resources faster than natural systems can regenerate or absorb waste from them, borrowed from systems ecology (Catton, Meadows) and applied to the global economy."@en ;
    skos:prefLabel "Ecological Overshoot"@en ;
    thinkr:convergesWith tgs:SchoolOfThought.DoughnutEconomics ;
    thinkr:influencedBy tgs:Persona.WilliamCatton .

tgs:Concept.PeakOil a thinkr:Concept,
        owl:NamedIndividual ;
    dcterms:source <https://www.thegreatsimplification.com> ;
    dcterms:subject tgs:Subject.EROIAndEnergyQuality ;
    skos:definition "The point at which the maximum rate of petroleum extraction is reached, after which production enters terminal decline — a formative concept in Hagens' background (he worked as a peak oil analyst before founding The Great Simplification) and foundational to his energy-decline framing."@en ;
    skos:prefLabel "Peak Oil"@en ;
    thinkr:influencedBy tgs:Persona.MKingHubbert .

tgs:Concept.Superorganism a thinkr:Concept,
        owl:NamedIndividual ;
    dcterms:source <https://www.thegreatsimplification.com> ;
    dcterms:subject tgs:Subject.SystemsFrameworks ;
    skos:definition "Framing human civilization as a single self-organizing, energy-and-resource-consuming entity whose collective behavior is not simply the sum of individual human intentions — echoing biological superorganism concepts (ant colonies, etc.) applied to techno-industrial society."@en ;
    skos:prefLabel "The Superorganism"@en ;
    thinkr:influencedBy tgs:Persona.EOWilson .

tgs:Concept.TheoryOfChange a thinkr:Concept,
        owl:NamedIndividual ;
    dcterms:source <https://www.thegreatsimplification.com/wp-content/uploads/2025/12/TGS-205-Nate-Hagens-Transcript.pdf> ;
    dcterms:subject tgs:Subject.CommunityAndResponse ;
    skos:definition "Hagens' stated approach to influence: rather than trying to reach and convert millions directly, cultivate a smaller network of well-informed people ('scout team') who shift the initial conditions from which broader social emergence unfolds."@en ;
    skos:prefLabel "Theory of Change (Emergence / Initial Conditions)"@en .

tgs:Concept.Wetware a thinkr:Concept,
        owl:NamedIndividual ;
    dcterms:source <https://www.thegreatsimplification.com> ;
    dcterms:subject tgs:Subject.BehavioralEconomicsAndCognition ;
    skos:definition "The idea that human cognitive and emotional wiring evolved for small-group, resource-scarce Pleistocene environments and is poorly matched to modern abundance, abstraction, and global-scale decision-making — a recurring lens Hagens uses to explain collectively self-destructive behavior."@en ;
    skos:prefLabel "Human 'Wetware' / Evolutionary Mismatch"@en ;
    thinkr:echoesIdeaOf tgs:Persona.SigmundFreud .

thinkr:Concept a owl:Class ;
    rdfs:comment "A term or idea from Nate Hagens' Great Simplification framework (e.g. Energy Blindness, the Superorganism)."@en ;
    rdfs:subClassOf skos:Concept ;
    skos:scopeNote "Narrower than skos:Concept: specifically an idea from Hagens' TGS framework, not a general classification term — do not confuse with thinkr:Subject, which is also a skos:Concept subclass but for topic classification, a different purpose entirely."@en ;
    skos:prefLabel "Concept"@en .

