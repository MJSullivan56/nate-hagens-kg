    skos:prefLabel "Marcus Aurelius"@en ;
    skos:scopeNote "MINIMAL shell only, deliberately. Marcus Aurelius is flagged in the 2026-07-13 handoff entry as a PURER Persona case than any modern guest (his public role IS essentially the entire historical record — no separately-attested private individual exists). That richer treatment belongs to Batch 5 (the Concept->Persona core mechanism migration), not this batch — do not build it out here ahead of that work."@en .

tgs:Persona.MartinLutherKingJr a thinkr:Persona, owl:NamedIndividual ;
    thinkr:actsThrough tgs:Human.MartinLutherKingJr ;
    skos:prefLabel "Martin Luther King Jr."@en .

