        owl:NamedIndividual ;
    thinkr:aboutObject tgs:Persona.Buddha ;
    thinkr:aboutSubject tgs:Concept.EnergyBlindness ;
    thinkr:calculatedConfidence thinkr:ConfidenceType.Candidate ;
    thinkr:hasEvidence tgs:Evidence.EnergyblindnessBuddha .

tgs:LinkNote.EnergyblindnessBerman a thinkr:LinkNote,
        owl:NamedIndividual ;
    thinkr:aboutObject tgs:Persona.ArtBerman ;
    thinkr:aboutSubject tgs:Concept.EnergyBlindness ;
    thinkr:calculatedConfidence thinkr:ConfidenceType.Candidate ;
    thinkr:hasEvidence tgs:Evidence.EnergyblindnessBerman ;
    skos:scopeNote "calculatedConfidence set here to match its single Evidence's Candidate confidence, following the same pattern as LinkNote.EnergyblindnessBuddha — but NOT verified by actually running scripts/compute_confidence.py, since that script wasn't available in this session. Re-run it before trusting this value as authoritative."@en .

