@prefix tgs:   <http://example.org/tgs#> .
@prefix thinkr: <http://example.org/thinkr#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/tgs#> a owl:Ontology ;
    owl:imports <http://example.org/thinkr#> ;
    rdfs:comment "Imports tgs-core for Protege compatibility — editing this file alone will resolve thinkr: classes/properties via the catalog file."@en ;
    .

#############################################
# BATCH 5 MIGRATION (2026-07-14, Persona-centered refactor, see
# docs/sidecar-cleanup-handoff.md): all 29 thinkr:aboutEntity triples
# that targeted a tgs:Human individual repointed to the corresponding
# tgs:Persona individual — a DBpedia/Wikidata identity mapping is
# fundamentally about the PUBLIC figure, the same reasoning applied
# throughout this whole refactor. The other 11 aboutEntity triples
# (targeting Organization/SchoolOfThought/Work individuals) are
# untouched — thinkr:aboutEntity's range was already the general
# thinkr:NamedEntity, no schema change needed, only the Human-specific
# instance data.
#############################################

#############################################
# thinkr:CrosswalkNote — replaces dbpedia_links.ttl and wikidata_links.ttl
# (both dissolved 2026-07-11) with a unified, provenance-bearing structure.
# Organized by the new class itself (CrosswalkNote), not by subject class
# (Person/School/Work) or by target database (DBpedia/Wikidata) — same
# "one class, one file" principle as everywhere else, and it naturally
# supersedes the earlier PersonCrosswalk/SchoolCrosswalk/WorkCrosswalk
# proposal since every crosswalk assertion now has real substantive
# content (the note) beyond a bare triple, same reasoning as why
# linknotes.ttl bundles its relation triples rather than splitting by
# Concept vs Person vs School.
#############################################

thinkr:CrosswalkNote a owl:Class ;
    rdfs:comment "Metadata for a single owl:sameAs crosswalk assertion (which database, when verified, caveats). Same sidecar pattern as thinkr:LinkNote — the actual owl:sameAs triple stays direct and reasoner-compatible, this individual references the same entity+URI pair separately via aboutEntity/aboutExternalURI, rather than reifying owl:sameAs itself."@en ;
    skos:prefLabel "Crosswalk Note"@en ;
    .

#############################################
# Instances
#############################################

tgs:CrosswalkNote.AristotleDBpedia a thinkr:CrosswalkNote,
        owl:NamedIndividual ;
    thinkr:aboutEntity tgs:Persona.Aristotle ;
    thinkr:aboutExternalURI <http://dbpedia.org/resource/Aristotle> ;
    thinkr:crosswalkSource thinkr:CrosswalkSource.DBpedia ;
    thinkr:verifiedOn "2026-07-11"^^xsd:date ;
    skos:scopeNote "Verified via direct web search confirming subject match before linking."@en ;
    .

