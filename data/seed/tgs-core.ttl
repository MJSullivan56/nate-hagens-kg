@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix dcmitype: <http://purl.org/dc/dcmitype/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix thinkr: <http://example.org/thinkr#> .

<http://example.org/thinkr#> a owl:Ontology ;
    rdfs:comment "TGS-core: reusable ontology (classes, properties, supporting-class instances) shared across any thinker's knowledge graph built on this pattern."@en .


thinkr:aboutObject a owl:ObjectProperty ;
    rdfs:domain thinkr:LinkNote ;
    skos:prefLabel "about object"@en .

thinkr:aboutSource a owl:ObjectProperty ;
    rdfs:comment "OPTIONAL. Absent when the Evidence is direct curator/maintainer reasoning rather than a citation to an external publication — such Evidence defaults to thinkr:ReliabilityType.Reputable for aggregation purposes (see that individual's definition)."@en ;
    rdfs:domain thinkr:Evidence ;
    rdfs:range thinkr:Source ;
    skos:prefLabel "about source"@en .

thinkr:aboutSubject a owl:ObjectProperty ;
    rdfs:domain thinkr:LinkNote ;
    skos:prefLabel "about subject"@en .

thinkr:appliesTo a owl:ObjectProperty ;
    rdfs:comment "For activists/practitioners rather than philosophers: this person's work is a concrete instance of the concept (e.g. MLK's organizing as an example of collective-action dynamics discussed under a TGS concept)."@en ;
    rdfs:domain thinkr:Person ;
    rdfs:range thinkr:Concept ;
    skos:prefLabel "provides real-world example of"@en .

thinkr:calculatedConfidence a owl:ObjectProperty ;
    rdfs:comment "DERIVED — computed from a LinkNote's Evidence set by scripts/compute_confidence.py. Never hand-write this value into a TTL file; it will drift out of sync with its own evidence. Re-run the compute script after adding/editing any Evidence."@en ;
    rdfs:domain thinkr:LinkNote ;
    rdfs:range thinkr:ConfidenceType ;
    skos:prefLabel "calculated confidence"@en .

thinkr:confidence a owl:ObjectProperty ;
    rdfs:comment "Has THIS piece of evidence been human-reviewed? Points to thinkr:ConfidenceType.Curated or .Candidate only (the other two values, Corroborated/Disputed, are LinkNote-only via thinkr:calculatedConfidence). Domain history: originally xsd:string on thinkr:Concept (wrong), then an enumerated object property on thinkr:LinkNote directly (better, but conflated the assertion with its evidence), now correctly on thinkr:Evidence as part of the Evidence/Source provenance model."@en ;
    rdfs:domain thinkr:Evidence ;
    rdfs:range thinkr:ConfidenceType .

thinkr:contrastsWith a owl:ObjectProperty ;
    rdfs:comment "Useful tension or disagreement worth surfacing to a learner, not just agreement."@en ;
    rdfs:subPropertyOf thinkr:relatesTo ;
    skos:scopeNote "Narrower than thinkr:relatesTo: specifically a useful tension or disagreement, not any relation — does not imply influence in either direction."@en ;
    skos:prefLabel "contrasts with"@en .

thinkr:definedIn a owl:ObjectProperty ;
    rdfs:domain thinkr:Concept ;
    rdfs:range thinkr:Work ;
    skos:prefLabel "primarily defined in"@en .

thinkr:discussedIn a owl:ObjectProperty ;
    rdfs:domain thinkr:Concept ;
    rdfs:range thinkr:Episode ;
    skos:prefLabel "discussed in episode"@en .

thinkr:echoesIdeaOf a owl:ObjectProperty ;
    rdfs:comment "The TGS concept independently converges on / restates an idea this person is known for. No claim of direct influence."@en ;
    rdfs:domain thinkr:Concept ;
    rdfs:range thinkr:Person ;
    rdfs:subPropertyOf thinkr:relatesTo ;
    skos:scopeNote "Narrower than thinkr:relatesTo: specifically independent convergence on a similar idea — explicitly NOT a claim of direct influence, see thinkr:influencedBy for that distinct, stronger case."@en ;
    skos:prefLabel "echoes idea of"@en .

thinkr:evidencePolarity a owl:ObjectProperty ;
    rdfs:domain thinkr:Evidence ;
    rdfs:range thinkr:PolarityType ;
    skos:prefLabel "evidence polarity"@en .

thinkr:hasEvidence a owl:ObjectProperty ;
    rdfs:domain thinkr:LinkNote ;
    rdfs:range thinkr:Evidence ;
    skos:prefLabel "has evidence"@en .

thinkr:influencedBy a owl:ObjectProperty ;
    rdfs:comment "Direct, citable influence — Hagens has referenced this person/school explicitly in developing the concept."@en ;
    rdfs:domain thinkr:Concept ;
    rdfs:range [ owl:unionOf ( thinkr:Person thinkr:SchoolOfThought thinkr:Organization thinkr:AcademicInstitution ) ] ;
    rdfs:subPropertyOf thinkr:relatesTo ;
    skos:scopeNote "Narrower than thinkr:relatesTo: specifically direct, citable influence (Hagens referenced this source explicitly) — see thinkr:echoesIdeaOf for the weaker, independent-convergence case."@en ;
    skos:prefLabel "influenced by"@en .

thinkr:memberOf a owl:ObjectProperty ;
    rdfs:domain thinkr:Person ;
    rdfs:range [ a owl:Class ; owl:unionOf ( thinkr:SchoolOfThought thinkr:Organization thinkr:AcademicInstitution ) ] ;
    skos:comment "Range widened 2026-07-11 when thinkr:School was split into SchoolOfThought/Organization/AcademicInstitution — see the three class declarations below for the reasoning."@en ;
    skos:prefLabel "member of / associated with"@en .

thinkr:reliabilityTier a owl:ObjectProperty ;
    rdfs:domain thinkr:Source ;
    rdfs:range thinkr:ReliabilityType ;
    skos:prefLabel "reliability tier"@en .

thinkr:ConfidenceType.Candidate a thinkr:ConfidenceType,
        owl:NamedIndividual ;
    skos:definition "On thinkr:Evidence: LLM-proposed or otherwise unreviewed. On thinkr:LinkNote's calculatedConfidence: no qualifying Curated+Supports evidence exists yet — the default/floor state."@en ;
    skos:prefLabel "Candidate"@en .

thinkr:ConfidenceType.Corroborated a thinkr:ConfidenceType,
        owl:NamedIndividual ;
    skos:definition "LinkNote-only (calculatedConfidence): two or more INDEPENDENT (different thinkr:Source individuals) Curated+Supports evidence from Reputable-or-better sources. Unverified-tier support cannot contribute toward this tier no matter how many pieces accumulate."@en ;
    skos:prefLabel "Corroborated"@en .

thinkr:ConfidenceType.Curated a thinkr:ConfidenceType,
        owl:NamedIndividual ;
    skos:definition "On thinkr:Evidence: human-reviewed and confirmed, not merely LLM-proposed. On thinkr:LinkNote's calculatedConfidence: exactly one independent Curated+Supports evidence from a Reputable-or-better source (see scripts/compute_confidence.py for the full rule)."@en ;
    skos:prefLabel "Curated"@en .

thinkr:ConfidenceType.Disputed a thinkr:ConfidenceType,
        owl:NamedIndividual ;
    skos:definition "LinkNote-only (calculatedConfidence): at least one Curated+Contests evidence from a Reputable-or-better source exists. This OVERRIDES Corroborated regardless of how much supporting evidence also exists — a serious rebuttal should surface for human attention, not get mathematically outvoted."@en ;
    skos:prefLabel "Disputed"@en .

thinkr:PolarityType.Contests a thinkr:PolarityType,
        owl:NamedIndividual ;
    skos:prefLabel "Contests"@en .

thinkr:PolarityType.Mentions a thinkr:PolarityType,
        owl:NamedIndividual ;
    skos:definition "Cites/discusses the claim without clearly arguing a position either way. Stored for context, never affects calculatedConfidence."@en ;
    skos:prefLabel "Mentions"@en .

thinkr:PolarityType.Supports a thinkr:PolarityType,
        owl:NamedIndividual ;
    skos:prefLabel "Supports"@en .

thinkr:ReliabilityType.Authoritative a thinkr:ReliabilityType,
        owl:NamedIndividual ;
    skos:definition "Wikidata, peer-reviewed academic publication, primary historical source. Strongest tier."@en ;
    skos:prefLabel "Authoritative"@en .

thinkr:ReliabilityType.Reputable a thinkr:ReliabilityType,
        owl:NamedIndividual ;
    skos:definition "Established journalism, credentialed-expert writing, or direct curator/maintainer reasoning that has itself been human-reviewed (thinkr:Evidence with no explicit thinkr:aboutSource defaults to this tier — see thinkr:aboutSource comment)."@en ;
    skos:prefLabel "Reputable"@en .

thinkr:ReliabilityType.Unreliable a thinkr:ReliabilityType,
        owl:NamedIndividual ;
    skos:definition "Known propaganda, misinformation, or otherwise discredited outlets. Evidence from Unreliable sources is stored (audit trail — 'we saw this, here's why it doesn't count') but EXCLUDED from calculatedConfidence entirely, regardless of polarity. A bad source doesn't make a claim less true; it just isn't signal worth counting either direction."@en ;
    skos:prefLabel "Unreliable"@en .

thinkr:ReliabilityType.Unverified a thinkr:ReliabilityType,
        owl:NamedIndividual ;
    skos:definition "Personal blogs, unreviewed Medium-style posts, anonymous sources. Can support a base Curated calculatedConfidence but can never push a LinkNote to Corroborated, regardless of volume."@en ;
    skos:prefLabel "Unverified"@en .

thinkr:convergesWith a owl:ObjectProperty, owl:SymmetricProperty ;
    rdfs:comment "Independently-developed ideas/frameworks converging on similar conclusions, with NO claimed causal lineage or direct influence — distinct from influencedBy/echoesIdeaOf, which both imply direction. Formally symmetric per OWL semantics, BUT this project's query tooling doesn't run a reasoner (same reason owl:NamedIndividual is asserted explicitly everywhere rather than relied on via subclass inference) — so BOTH directions must be explicitly asserted as real triples, or querying from the 'other' side returns nothing. Verified empirically 2026-07-11: querying tgs:SchoolOfThought.DoughnutEconomics thinkr:convergesWith ?x returned zero results until the reverse triple was added by hand, despite the forward direction being asserted and the property being formally symmetric. First used for tgs:Concept.Overshoot <-> tgs:SchoolOfThought.DoughnutEconomics."@en ;
    skos:prefLabel "converges with"@en .

thinkr:NamedEntity a owl:Class ;
    rdfs:comment "Superclass for anything that can be surfaced via the NER pipeline (extraction/index_named_entities.py) and formally modeled in the graph. thinkr:Person is currently the only subclass — deliberately left room for others (e.g. an Organization class) to join later without redesigning this. Plain owl:Class, not SKOS — added 2026-07-11 at MJSullivan's direction, correcting an earlier proposal to use SKOS for the same purpose."@en ;
    skos:prefLabel "Named Entity"@en .

thinkr:NamedEntityType a owl:Class ;
    rdfs:comment "ABSTRACT top-level category class — restructured 2026-07-11 per MJSullivan: each thinkr:NamedEntity subclass gets its OWN more specific categorization as a subclass of this one (e.g. thinkr:PersonEntityType for thinkr:Person), rather than one flat enumeration shared across every subclass. Mirrors the class hierarchy: thinkr:NamedEntity -> thinkr:Person is paralleled by thinkr:NamedEntityType -> thinkr:PersonEntityType. A future Organization subclass would get its own thinkr:OrganizationEntityType sibling, not reuse Person's categories."@en ;
    skos:prefLabel "Named Entity Type"@en .

thinkr:hasNamedEntityType a owl:ObjectProperty ;
    rdfs:domain thinkr:NamedEntity ;
    rdfs:range thinkr:NamedEntityType ;
    rdfs:comment "GENERAL, top-level property — in practice, use a subclass-specific subproperty instead (e.g. thinkr:hasPersonEntityType for a thinkr:Person). This property exists mainly for uniform querying across ALL NamedEntity subclasses at once, once more than one exists."@en ;
    skos:prefLabel "has named entity type"@en .

thinkr:PersonEntityType a owl:Class, thinkr:Category ;
    rdfs:subClassOf thinkr:NamedEntityType ;
    skos:scopeNote "Narrower than thinkr:NamedEntityType: specifically the categorization scheme for thinkr:Person individuals. A hypothetical future OrganizationEntityType would be a SIBLING of this, not a further subclass — see the OWL-depth-cap governance rule in CLAUDE.md."@en ;
    rdfs:comment "Categorizes a thinkr:Person's relationship to TGS specifically. Flat categories, deliberately NOT SKOS — unlike Subject/sub-topics, these don't nest hierarchically. ReallyBadActor/Critic-style category proposed but NOT YET CONFIRMED as of 2026-07-11 — only add if/when explicitly confirmed, don't guess."@en ;
    skos:prefLabel "Person Entity Type"@en .

thinkr:PersonEntityType.Guest a thinkr:PersonEntityType, owl:NamedIndividual ;
    skos:prefLabel "Guest"@en .

thinkr:PersonEntityType.Collaborator a thinkr:PersonEntityType, owl:NamedIndividual ;
    skos:prefLabel "Collaborator"@en .

thinkr:PersonEntityType.CoAuthor a thinkr:PersonEntityType, owl:NamedIndividual ;
    skos:prefLabel "Co-Author"@en .

thinkr:PersonEntityType.Contributor a thinkr:PersonEntityType, owl:NamedIndividual ;
    skos:prefLabel "Contributor"@en ;
    rdfs:comment "Designed pre-dinner 2026-07-11 (Contributor IFF publications align with the movement, else just a Mention) but never actually instantiated until Iain McGilchrist's bootstrap gave a real, well-evidenced case: published works (The Master and His Emissary, The Matter with Things) genuinely align with TGS's cognitive/behavioral themes. Not mutually exclusive with Guest — a Person can hold both independently."@en .

thinkr:PersonEntityType.Critic a thinkr:PersonEntityType, owl:NamedIndividual ;
    skos:prefLabel "Critic"@en ;
    rdfs:comment "Motivated by Elon Musk (2026-07-11) — someone whose relationship to TGS is oppositional, distinct from the Contributor/Mention question (which is about publication alignment, not stance). Schema-only for now, per MJSullivan: 'add critic for now and enrich things later' — no Person individual tagged with this yet."@en .

thinkr:hasPersonEntityType a owl:ObjectProperty ;
    rdfs:subPropertyOf thinkr:hasNamedEntityType ;
    skos:scopeNote "Narrower than thinkr:hasNamedEntityType: the property to actually use for thinkr:Person individuals in practice."@en ;
    rdfs:domain thinkr:Person ;
    rdfs:range thinkr:PersonEntityType ;
    rdfs:comment "The property to actually USE for Person individuals — subPropertyOf the general thinkr:hasNamedEntityType. Same explicit-typing caveat as elsewhere in this project: rdfs:subPropertyOf won't make a hasPersonEntityType triple automatically queryable via hasNamedEntityType without a reasoner (this project's tooling doesn't run one) — assert both explicitly if a query needs to work at the general level."@en ;
    skos:prefLabel "has person entity type"@en .

thinkr:CrosswalkSource a owl:Class, thinkr:Category ;
    rdfs:comment "Which external database a thinkr:CrosswalkNote's owl:sameAs assertion targets. Closed enumeration."@en ;
    skos:prefLabel "Crosswalk Source"@en .

thinkr:CrosswalkSource.DBpedia a thinkr:CrosswalkSource, owl:NamedIndividual ;
    skos:prefLabel "DBpedia"@en .

thinkr:CrosswalkSource.Wikidata a thinkr:CrosswalkSource, owl:NamedIndividual ;
    skos:prefLabel "Wikidata"@en .

thinkr:aboutEntity a owl:ObjectProperty ;
    rdfs:domain thinkr:CrosswalkNote ;
    rdfs:range thinkr:NamedEntity ;
    rdfs:comment "The Person/School/Work etc. this crosswalk note documents an external mapping for."@en ;
    skos:prefLabel "about entity"@en .

thinkr:aboutExternalURI a owl:ObjectProperty ;
    rdfs:domain thinkr:CrosswalkNote ;
    rdfs:comment "The external URI (DBpedia/Wikidata resource) this crosswalk note documents — mirrors the actual owl:sameAs triple's object, kept direct and reasoner-compatible rather than reified."@en ;
    skos:prefLabel "about external URI"@en .

thinkr:crosswalkSource a owl:ObjectProperty ;
    rdfs:domain thinkr:CrosswalkNote ;
    rdfs:range thinkr:CrosswalkSource ;
    skos:prefLabel "crosswalk source"@en .

thinkr:verifiedOn a owl:DatatypeProperty ;
    rdfs:domain thinkr:CrosswalkNote ;
    rdfs:range xsd:date ;
    skos:prefLabel "verified on"@en .

thinkr:EpisodeType a owl:Class, thinkr:Category ;
    rdfs:comment "Structural format of a thinkr:Episode — deliberately generic and reusable across any future thinker's graph, independent of any one show's own branding for these formats (e.g. TGS calls its Monologue-type content 'Frankly' and its PanelDiscussion-type content 'Reality Roundtables' — those show-specific terms live as skos:altLabel on the generic values below, not as separate classes)."@en ;
    skos:prefLabel "Episode Type"@en .

thinkr:EpisodeType.Interview a thinkr:EpisodeType, owl:NamedIndividual ;
    skos:prefLabel "Interview"@en ;
    skos:altLabel "interview"@en, "Guest Interview"@en, "One-on-One Interview"@en .

thinkr:EpisodeType.PanelDiscussion a thinkr:EpisodeType, owl:NamedIndividual ;
    skos:prefLabel "Panel Discussion"@en ;
    skos:altLabel "roundtable"@en, "Reality Roundtable"@en, "Panel"@en, "Multi-Guest Discussion"@en .

thinkr:EpisodeType.Monologue a thinkr:EpisodeType, owl:NamedIndividual ;
    skos:prefLabel "Monologue"@en ;
    skos:altLabel "frankly"@en, "Frankly"@en, "Solo Reflection"@en, "Solo Episode"@en .

thinkr:hasEpisodeType a owl:ObjectProperty ;
    rdfs:domain thinkr:Episode ;
    rdfs:range thinkr:EpisodeType ;
    skos:prefLabel "has episode type"@en .

thinkr:hasCanonicalSource a owl:ObjectProperty ;
    rdfs:subPropertyOf dcterms:source ;
    rdfs:domain thinkr:Episode ;
    skos:scopeNote "The canonical page for this Episode — expected cardinality of exactly one, unlike the general dct:source (still used elsewhere in this graph, e.g. Work.CaliforniaDoughnutReport2025, with no such cardinality expectation). subPropertyOf lets this stay a genuine dct:source for anything that reads it generically, while carrying a narrower, Episode-specific meaning here — a scopeNote directly on dct:source itself would incorrectly apply globally to every other use of that property in this graph."@en .

thinkr:hasReplay a owl:ObjectProperty ;
    rdfs:domain thinkr:Work ;
    skos:scopeNote "A link to watch/listen to a replay (YouTube, Spotify, etc.) — multi-valued, one triple per platform. Domain deliberately kept at thinkr:Work, not narrowed to Episode: some future Work subtypes (e.g. an audiobook) could plausibly have a replay too. Many Work subtypes (Book, WhitePaper, PhDThesis) genuinely won't — that's a fact about the specific instance, not something enforced structurally."@en .

thinkr:hasTranscript a owl:ObjectProperty ;
    rdfs:domain thinkr:Work ;
    skos:scopeNote "A link to a text transcript, distinct from thinkr:hasReplay (audio/video) and thinkr:hasCanonicalSource (the page about the content, not the content itself)."@en .

thinkr:ProfessionalRole a owl:Class, thinkr:Category ;
    rdfs:comment "A person's intrinsic professional identity (Educator, Author, etc.) — deliberately generic and reusable across any future thinker's graph, same reasoning as thinkr:EpisodeType. Distinct from thinkr:PersonEntityType, which describes a person's RELATIONSHIP TO THIS SPECIFIC PROJECT (Guest, Contributor), not something intrinsic to them independent of it."@en ;
    skos:prefLabel "Professional Role"@en .

thinkr:ProfessionalRole.Educator a thinkr:ProfessionalRole, owl:NamedIndividual ;
    skos:prefLabel "Educator"@en .

thinkr:ProfessionalRole.InstituteExecutive a thinkr:ProfessionalRole, owl:NamedIndividual ;
    skos:prefLabel "Institute Executive"@en .

thinkr:ProfessionalRole.Blogger a thinkr:ProfessionalRole, owl:NamedIndividual ;
    skos:prefLabel "Blogger"@en .

thinkr:ProfessionalRole.Author a thinkr:ProfessionalRole, owl:NamedIndividual ;
    skos:prefLabel "Author"@en .

thinkr:hasProfessionalRole a owl:ObjectProperty ;
    rdfs:domain thinkr:Person ;
    rdfs:range thinkr:ProfessionalRole ;
    skos:scopeNote "General-purpose grouping, NOT provenance-tracked — unlike memberOf/AffiliationNote (still pending its own design, see docs/sidecar-cleanup-handoff.md), this doesn't claim when/how the role was verified, just that it's a useful high-level label."@en .

thinkr:hasTGSRole a owl:ObjectProperty ;
    rdfs:subPropertyOf thinkr:hasProfessionalRole ;
    rdfs:range [ a owl:Class ; owl:oneOf (
        thinkr:ProfessionalRole.Educator
        thinkr:ProfessionalRole.InstituteExecutive
        thinkr:ProfessionalRole.Blogger
        thinkr:ProfessionalRole.Author
    ) ] ;
    skos:scopeNote "Curated subset of thinkr:ProfessionalRole specifically useful for people in the TGS orbit. The range restriction is DOCUMENTATION ONLY, not enforced — this project currently has exactly two editors (MJSullivan and Claude), so a manually-respected convention is sufficient; would need a real validation script if that ever changes."@en .

thinkr:hasHost a owl:ObjectProperty ;
    rdfs:subPropertyOf dcterms:creator ;
    rdfs:domain thinkr:Work ;
    skos:scopeNote "The person who hosts/leads this Work — distinct from dct:creator's broader sense, which for other Work subtypes might mean author, director, etc. instead. Same reasoner caveat as thinkr:hasPersonEntityType: doesn't make the fact queryable via bare dct:creator without a reasoner."@en .

thinkr:hasGuest a owl:ObjectProperty ;
    rdfs:subPropertyOf dcterms:contributor ;
    rdfs:domain thinkr:Work ;
    skos:scopeNote "A person being interviewed/featured — distinct from dct:contributor's broader sense (editor, co-author, etc. for other Work subtypes)."@en .

thinkr:Series a owl:Class ;
    rdfs:subClassOf thinkr:Work, dcmitype:Collection ;
    rdfs:comment "The overarching arc itself (e.g. 'How to Think About the Future'), distinct from any single installment. First instance added 2026-07-11 (Series.HowToThinkAboutTheFuture, with 3 stub Frankly installments) — no longer zero-instance."@en ;
    skos:scopeNote "Dual superclass, same pattern as thinkr:Person (foaf:Person + thinkr:NamedEntity): narrower than thinkr:Work in that it has real Work-like properties (title, host, potentially subject) — but a Series has no standalone content of its own (no replay, no transcript), which is exactly what dcmitype:Collection (an aggregation of resources, membership understood via description of the aggregation) captures and thinkr:Work alone does not. dct:isPartOf/dct:hasPart (used on each installment) are the DCMI-standard properties for exactly this relationship — Collection is their natural target type, not an arbitrary addition."@en ;
    skos:prefLabel "Series"@en .

thinkr:seriesPosition a owl:DatatypeProperty ;
    rdfs:domain thinkr:Work ;
    rdfs:range xsd:integer ;
    skos:scopeNote "Ordinal position within the thinkr:Series pointed to by dct:isPartOf on the same individual — e.g. 2 for Part 2. No Dublin Core term exists for this specifically, minted directly (unlike dct:references/dct:isPartOf, which are used as-is with no subproperty needed — both already carry the right generic meaning)."@en .

thinkr:relatesTo a owl:ObjectProperty ;
    rdfs:comment "Generic, loosely-typed link. Use a more specific property below when it fits."@en ;
    rdfs:domain thinkr:Concept ;
    rdfs:range [ owl:unionOf ( thinkr:Concept thinkr:Person thinkr:SchoolOfThought thinkr:Organization thinkr:AcademicInstitution ) ] ;
    skos:prefLabel "relates to"@en .

thinkr:PolarityType a owl:Class, thinkr:Category ;
    rdfs:comment "Whether a piece of evidence supports, contests, or merely mentions a LinkNote's claim. Independent of source reliability — polarity is about the evidence's stance, reliability is about the source's trustworthiness."@en ;
    owl:equivalentClass [ a owl:Class ;
            owl:oneOf ( thinkr:PolarityType.Supports thinkr:PolarityType.Contests thinkr:PolarityType.Mentions ) ] ;
    skos:prefLabel "Polarity Type"@en .

thinkr:ReliabilityType a owl:Class, thinkr:Category ;
    rdfs:comment "Enumerated reliability of a thinkr:Source (the publication/venue), independent of what any given piece of evidence from it argues. A source's tier is an editorial judgment call, not an objective formula — expect it to need periodic revisiting, the same way Wikipedia's own reliable-sources list is a living, contested, human-adjudicated thing."@en ;
    owl:equivalentClass [ a owl:Class ;
            owl:oneOf ( thinkr:ReliabilityType.Authoritative thinkr:ReliabilityType.Reputable thinkr:ReliabilityType.Unverified thinkr:ReliabilityType.Unreliable ) ] ;
    skos:prefLabel "Reliability Type"@en .

thinkr:Category a owl:Class ;
    rdfs:comment "A special class whose instances are enumerated and curated, used to further categorize instances of OTHER classes for more specificity — not a domain entity itself. Formalized 2026-07-11 per MJSullivan's exact definition, marking a pattern that was already implicit in ConfidenceType/ReliabilityType/PolarityType and just-built PersonEntityType. Classes are marked as Category via 'a thinkr:Category' (OWL punning — a class doubling as an instance of this meta-class), not rdfs:subClassOf, since Category-ness is a property of the CLASS itself, not something its own individuals (e.g. ConfidenceType.Curated) inherit. NOTE: thinkr:NamedEntityType is deliberately NOT marked Category — it has zero direct instances of its own (only its subclass PersonEntityType does), so it doesn't meet 'has enumerated curated instances' literally. It's an organizing abstraction, not a Category proper."@en ;
    skos:prefLabel "Category"@en .

thinkr:ConfidenceType a owl:Class, thinkr:Category ;
    rdfs:comment "Enumerated class of allowed review/aggregation states. thinkr:Evidence uses only Curated/Candidate (has THIS piece of evidence been human-reviewed?). thinkr:LinkNote uses the full range via thinkr:calculatedConfidence, which is DERIVED — computed from a LinkNote's Evidence set by scripts/compute_confidence.py, never hand-asserted. Closed enumeration via owl:oneOf."@en ;
    owl:equivalentClass [ a owl:Class ;
            owl:oneOf ( thinkr:ConfidenceType.Curated thinkr:ConfidenceType.Candidate thinkr:ConfidenceType.Corroborated thinkr:ConfidenceType.Disputed ) ] ;
    skos:prefLabel "Confidence Type"@en .

