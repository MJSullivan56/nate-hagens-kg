# Generated RDF from the promote workflow — decide deliberately whether
# to commit this or keep regenerating it; gitignored by default here
data/generated/

# Downloaded transcripts (large, regeneratable — keep the repo lean;
# store the fetch list/script instead, not the PDFs themselves)
extraction/transcripts_raw/
extraction/substack_summaries_raw/
extraction/cited_sources_raw/
extraction/substack_text_cache/
extraction/transcripts_text_cache/
extraction/*.pdf

