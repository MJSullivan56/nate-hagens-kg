@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix tgs: <http://example.org/tgs#> .
@prefix thinkr: <http://example.org/thinkr#> .

tgs: a owl:Ontology ;
    rdfs:comment "Imports tgs-core for Protege compatibility — editing this file alone will resolve thinkr: classes/properties via the catalog file."@en ;
    owl:imports thinkr: .

#############################################
# BATCH 5 MIGRATION (2026-07-14, Persona-centered refactor, see
# docs/sidecar-cleanup-handoff.md): every tgs:Human.X reference in this
# file repointed to the corresponding tgs:Persona.X — both the direct
# Concept->thinker property statements (echoesIdeaOf/influencedBy/
# contrastsWith, near the bottom of this file) AND every LinkNote's own
# aboutObject/aboutSubject value. These two representations describe
# the SAME underlying fact (e.g. LinkNote.ComplexityTainter's
# aboutObject and Concept.ComplexityCollapse's influencedBy both assert
# the identical Tainter/Complexity-Collapse connection) — migrating one
# without the other would have split a single fact across two
# inconsistent representations. This IS the graph's actual core
# mechanism, the reason LinkNote/Evidence/compute_confidence.py exist
# at all — flagged repeatedly across earlier sessions as the real
# reason the whole Persona architecture was built, not yet executed
# until now. thinkr:appliesTo (used once, tgs:Persona.MartinLutherKingJr
# thinkr:appliesTo tgs:Concept.GrowthImperative below) was ALSO migrated
# to Persona — MJSullivan explicitly approved this after initially being
# flagged as out of scope. Its instance triple had actually already been
# repointed as a side effect of this file's blanket Human->Persona text
# replacement (the replacement wasn't scoped to specific predicates);
# only the property's rdfs:domain in tgs-core.ttl needed a follow-up fix
# to match.
#############################################

tgs:LinkNote.ComplexityTainter a thinkr:LinkNote,
        owl:NamedIndividual ;
    thinkr:aboutObject tgs:Persona.JosephTainter ;
    thinkr:aboutSubject tgs:Concept.ComplexityCollapse ;
    thinkr:calculatedConfidence thinkr:ConfidenceType.Curated ;
    thinkr:hasEvidence tgs:Evidence.ComplexityTainter .

tgs:LinkNote.DiscountMarcus a thinkr:LinkNote,
        owl:NamedIndividual ;
    thinkr:aboutObject tgs:Persona.MarcusAurelius ;
    thinkr:aboutSubject tgs:Concept.DiscountRatesAndPresentBias ;
    thinkr:calculatedConfidence thinkr:ConfidenceType.Curated ;
    thinkr:hasEvidence tgs:Evidence.DiscountMarcus .

