@prefix tgs:   <http://example.org/tgs#> .
@prefix thinkr: <http://example.org/thinkr#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/tgs#> a owl:Ontology ;
    owl:imports <http://example.org/thinkr#> ;
    rdfs:comment "Imports tgs-core for Protege compatibility — editing this file alone will resolve thinkr: classes/properties via the catalog file."@en .

#############################################
# thinkr:Work — promoted out of tgs-core.ttl on 2026-07-11, its first
# real instance (governance principle: classes get their own file once
# they have real content, not before).
#############################################

thinkr:Work a owl:Class ;
    rdfs:comment "A book, essay, or other work in which a concept or idea is developed."@en ;
    rdfs:subClassOf dct:BibliographicResource ;
    skos:scopeNote "Narrower than dct:BibliographicResource: specifically a work in which a TGS-relevant concept is developed, not any bibliographic item in general."@en ;
    skos:prefLabel "Work"@en .

tgs:Work.CaliforniaDoughnutReport2025 a thinkr:Work, owl:NamedIndividual ;
    skos:prefLabel "The California Doughnut Snapshot and Report"@en ;
    rdfs:comment "Authors: Alaitz Aritza (data manager), Julian Kraus-Polk (editor), California Doughnut Economics Coalition. Published November 6, 2025, v1. Examines 42 social/ecological indicators across 21 categories; finds California overshooting 89% of ecological indicators (average overshoot 286%) while falling short on 100% of social indicators assessed. CC-BY 4.0 licensed — more permissive than most sources in this graph, direct quotation with attribution is explicitly permitted."@en ;
    dct:source <https://zenodo.org/records/17540639> ;
    dct:license <https://creativecommons.org/licenses/by/4.0/legalcode> .

tgs:Work.TheMasterAndHisEmissary a thinkr:Work, owl:NamedIndividual ;
    skos:prefLabel "The Master and His Emissary: The Divided Brain and the Making of the Western World"@en ;
    rdfs:comment "2009 book by Iain McGilchrist (Yale University Press). Argues the brain's two hemispheres offer fundamentally different kinds of attention to the world, and that Western culture has become dominated by narrow, left-hemisphere thinking at the expense of the right's broader, contextual awareness. Sold over 200,000 copies."@en ;
    dct:creator tgs:Human.IainMcGilchrist .

tgs:Work.TheMatterWithThings a thinkr:Work, owl:NamedIndividual ;
    skos:prefLabel "The Matter with Things: Our Brains, Our Delusions, and the Unmaking of the World"@en ;
    rdfs:comment "2021 book by Iain McGilchrist (Perspectiva Press), extending The Master and His Emissary's hemisphere hypothesis into epistemology and metaphysics — 1,500 pages across two volumes."@en ;
    dct:creator tgs:Human.IainMcGilchrist .

tgs:Work.RealityBlind a thinkr:Work, owl:NamedIndividual ;
    skos:prefLabel "Reality Blind: Integrating the Systems Science Underpinning Our Collective Futures, Vol. 1"@en ;
    rdfs:comment "Co-authored with DJ White — DJ White NOT modeled as a Person individual as of 2026-07-11, would need the same verification pass as every other person tonight (Wikipedia/wrong-person checks), not fabricated as a side effect of fleshing out Nate. Self-published on Amazon (ISBN 9798701116281) specifically so full content could stay free online — was the primary text for Nate's Reality 101 course. Confirmed via multiple independent sources: Amazon, Goodreads, a LinkedIn post from Nate himself, MAHB, Stanford."@en ;
    dct:issued "2021"^^xsd:gYear ;
    dct:creator tgs:Human.NateHagens .
