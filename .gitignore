# Oxigraph store (binary, local, regenerated via load_oxigraph.sh)
tgs_store/
scripts/tgs_store/
*.oxigraph/

# Python
__pycache__/
*.pyc
.venv/
venv/

# DuckDB staging (local review queue — not source of truth)
extraction/staging.duckdb
