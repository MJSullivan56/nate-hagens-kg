@prefix foaf:  <http://xmlns.com/foaf/0.1/> .
@prefix tgs:   <http://example.org/tgs#> .
@prefix thinkr: <http://example.org/thinkr#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .

<http://example.org/tgs#> a owl:Ontology ;
    owl:imports <http://example.org/thinkr#> ;
    rdfs:comment "Imports tgs-core for Protege compatibility — editing this file alone will resolve thinkr: classes/properties via the catalog file."@en .

#############################################
# thinkr:Persona — Batch 0/1 of the Persona-centered refactor
# (docs/sidecar-cleanup-handoff.md, "SESSION CUT OFF (2026-07-14)").
# Same promotion precedent as thinkr:Relationship: class + its own
# instances live together in their own file (one-class-one-file),
# rather than splitting class into tgs-core.ttl.
#
# FINAL PRINCIPLE (settled 2026-07-14, prototyped in
# persona_human_prototype-8.ttl): no Human-to-Human relationships
# anywhere in this graph. The ONLY relationship type touching Human at
# all is thinkr:actsThrough (Persona -> Human, biographical anchor).
# Every other relationship — Episode hosting/guesting, Relationship
# individuals, eventually Concept->influencedBy/echoesIdeaOf — runs
# through Persona instead. Human becomes a pure leaf node: biographical
# facts only (name, birthdate, earned credentials, employment history).
#
# SCOPE OF THIS BATCH, deliberately narrow: create ONE Persona per
# existing Human, uniformly MINIMAL (actsThrough + prefLabel only) —
# including Nate's, even though the prototype gave his a rich buildout
# (hasTGSRole, foaf:homepage, hasPersonalRelationship/
# hasProfessionalRelationship). That richer content is deliberately NOT
# ported here: it only becomes meaningful once Batch 3 actually flips
# Relationship.hasSubject from Human to Persona. Moving it early would
# create a duplicate, conflicting source of truth between
# Human.NateHagens and Persona.NateHagens for the batches in between.
# Same discipline for Marcus Aurelius's "purer persona" case (near-empty
# Human, Persona carrying essentially all content, per the 2026-07-13
# escalation) — deferred to Batch 5 (the core Concept->Persona
# migration), not built here.
#
# NAMING NOTE: uses tgs:Persona.<X> matching the REAL tgs:Human.<X> IRI
# suffix already in humans.ttl — NOT persona_human_prototype-8.ttl's
# tgs:Human.NathanHagens, which was prototype-only naming and never
# matched the real graph's tgs:Human.NateHagens.
#############################################

thinkr:Persona a owl:Class ;
    rdfs:subClassOf thinkr:NamedEntity ;
    rdfs:comment "The public-facing identity a Human operates under. Every Relationship, Episode hosting/guesting fact, and (eventually) intellectual-influence claim in this graph belongs to a Persona, not a Human directly — Human holds only biographical facts and is reached solely via thinkr:actsThrough. A new Persona is warranted ONLY when the public name/brand itself genuinely differs from the Human's name (Cher-vs-legal-name level) — not for different professional capacities under one consistent public name, which are multiple thinkr:hasTGSRole values on a single Persona instead."@en ;
    skos:prefLabel "Persona"@en .

thinkr:actsThrough a owl:ObjectProperty ;
    rdfs:domain thinkr:Persona ;
    rdfs:range thinkr:Human ;
    rdfs:comment "Links a Persona back to the Human(s) behind it — the ONLY property in this graph that connects a Persona to a Human. Naming/directionality borrowed from DOLCE+DnS Ultralite's actsThrough/actsFor pair (examined directly 2026-07-12; this was the one piece of DOLCE flagged as worth keeping)."@en ;
    skos:prefLabel "acts through"@en .

thinkr:hasPersona a owl:ObjectProperty ;
    rdfs:domain thinkr:Human ;
    rdfs:range thinkr:Persona ;
    skos:comment "Explicit inverse of thinkr:actsThrough, asserted directly rather than via owl:inverseOf — consistent with this project's standing practice of asserting both directions explicitly since the toolchain never runs a reasoner (same precedent as dct:hasPart/dct:isPartOf on Series). Multi-valued: Human->Persona is 1..n — one Human may have more than one genuinely distinct public identity, though most individuals in this graph have exactly one."@en ;
    skos:prefLabel "has persona"@en .

#############################################
# Instances — one minimal Persona per existing Human (humans.ttl, 25
# individuals as of 2026-07-14). Uniformly minimal per the scope note
# above: actsThrough + prefLabel (mirroring the Human's own prefLabel)
# only. hasPersonEntityType (Guest/Contributor, currently on the Human
# individuals for Monahan/McGilchrist/Schmachtenberger) deliberately
# NOT moved here yet — same "don't build ahead of real need" discipline,
# revisit once Batch 3 clarifies whether that property belongs on
# Persona instead.
#############################################

tgs:Persona.Aristotle a thinkr:Persona, owl:NamedIndividual ;
    thinkr:actsThrough tgs:Human.Aristotle ;
    skos:prefLabel "Aristotle"@en .

tgs:Persona.Buddha a thinkr:Persona, owl:NamedIndividual ;
    thinkr:actsThrough tgs:Human.Buddha ;
    skos:prefLabel "Gautama Buddha"@en .

