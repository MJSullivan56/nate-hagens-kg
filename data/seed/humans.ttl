@prefix dbo: <http://dbpedia.org/ontology/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix tgs: <http://example.org/tgs#> .
@prefix thinkr: <http://example.org/thinkr#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/tgs#> a owl:Ontology ;
    owl:imports <http://example.org/thinkr#> ;
    rdfs:comment "Imports tgs-core for Protege compatibility — editing this file alone will resolve thinkr: classes/properties via the catalog file."@en ;
    .


#############################################
# Classes and Properties
#############################################

thinkr:Human a owl:Class ;
    rdfs:comment "A philosopher, scientist, activist, or thinker being linked to a TGS concept."@en ;
    rdfs:subClassOf foaf:Person, thinkr:NamedEntity ;
    skos:scopeNote "Narrower than foaf:Person: specifically a person being linked to a TGS concept, not any person. Narrower than thinkr:NamedEntity: specifically the subset explicitly typed Person, as distinct from a hypothetical future Organization subclass."@en ;
    skos:prefLabel "Person"@en ;
    .

#############################################
